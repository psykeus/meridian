# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=meridian
POSTGRES_PASSWORD=meridian
POSTGRES_DB=meridian
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI / LLM (all optional — platform works without these) ──────────────────
# LiteLLM routes to any provider. Set ONE of the following blocks.

# Option A: OpenAI
# LITELLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Option B: Anthropic
# LITELLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option C: Groq (fast + cheap)
# LITELLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...

# Option D: Ollama (fully local, no API key required)
# LITELLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Default model name (used by LiteLLM — format depends on provider)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2

# ─── Data Feed API Keys (all optional — feeds without keys still work) ────────
ACLED_API_KEY=
ACLED_EMAIL=

ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

NASA_API_KEY=DEMO_KEY

FRED_API_KEY=

# X (Twitter) API — required only for social OSINT panel
TWITTER_BEARER_TOKEN=

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Space-Track.org — required only for satellite catalog
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# ─── Email (optional — for alert delivery) ───────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── Stripe (optional — for billing/subscription tiers) ──────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ANALYST=
STRIPE_PRICE_TEAM_STARTER=
STRIPE_PRICE_TEAM_PRO=

# ─── Google OAuth (optional — for SSO login) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Collab server ────────────────────────────────────────────────────────────
COLLAB_PORT=1234
COLLAB_HOST=0.0.0.0

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ─── Phase 4: Data Feed Keys (all optional — feeds work without them) ─────────
# EIA (US Energy Information Administration) — https://www.eia.gov/opendata/
EIA_API_KEY=

# ENTSO-E (EU energy transparency) — https://transparency.entsoe.eu/
ENTSO_E_API_KEY=

# NASA NeoWs (Near-Earth Objects) — https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# OpenSanctions — https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# US State Dept Travel Advisories (no key required)
# FAA NOTAMs — https://api.faa.gov/
FAA_CLIENT_ID=
FAA_CLIENT_SECRET=

# FRED (Federal Reserve) — https://fred.stlouisfed.org/docs/api/
FRED_API_KEY=

# Telegram Bot (for OSINT channel monitoring) — https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
